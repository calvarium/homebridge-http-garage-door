{
  "name": "homebridge-garage-door-shelly1",
  "version": "1.1.6",
  "description": "Homebridge plugin for a simple garage door opener using Shelly 1 relay",
  "main": "index.js",
  "engines": {
    "homebridge": ">=0.4.50",
    "node": ">=12.13.0"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "jest",
    "deploy": "set -a && . ./.env && set +a && rsync -av --exclude='node_modules' --exclude='.git' --exclude='.github' --exclude='.venv' --exclude='test' ./ ${HOMEBRIDGE_USER}@${HOMEBRIDGE_HOST}:${HOMEBRIDGE_PLUGIN_PATH}/ && ssh ${HOMEBRIDGE_USER}@${HOMEBRIDGE_HOST} \"cd ${HOMEBRIDGE_PLUGIN_PATH} && /opt/homebridge/bin/node /opt/homebridge/bin/npm install --omit=dev --no-fund --no-audit\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calvarium/homebridge-http-garage-door.git"
  },
  "dependencies": {
    "jsonpath-plus": "^10.4.0",
    "ws": "^8.18.2"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge",
    "garage",
    "garagedoor",
    "home",
    "remote",
    "shelly",
    "shelly1"
  ],
  "author": "Miguel Ferreira",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/calvarium/homebridge-http-garage-door/issues"
  },
  "homepage": "https://github.com/calvarium/homebridge-http-garage-door#readme",
  "devDependencies": {
    "eslint": "^9.29.0",
    "jest": "^30.0.2"
  }
}
